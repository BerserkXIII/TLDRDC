# ══════════════════════════════════════════════════════════════════════════
# TLDRDC v1.0 - Professional .gitignore
# ══════════════════════════════════════════════════════════════════════════

# ─ Python Cache & Compiled
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.Python

# ─ Virtual Environments
venv/
env/
ENV/
env.bak/
venv.bak/

# ─ Build & Distribution (PyInstaller)
build/
dist/
*.spec  # PyInstaller spec files (regenerable)

# ─ Debug Modules & Reports (v1.0 Development - Aislado)
z_debug_modules/
z_debug_reports/

# ─ IDE & Editor
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ─ OS
Thumbs.db
.DS_Store
ehthumbs.db

# ─ Testing
.pytest_cache/
.coverage/
htmlcov/

# ─ Temporary Files
*.tmp
*.temp
*.bak

# ─ Environment Variables
.env
.env.local
.env.*.local

# ─ Optional Development Tools
local_settings.py
ui_tester/